# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI (TTS + Whisper)
OPENAI_API_KEY=

# Pexels
PEXELS_API_KEY=

# YouTube OAuth2
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# 로컬에서 node-cron 상시 실행할 때만 사용 (GitHub Actions면 불필요)
UPLOAD_TIME_CRON="0 22 * * *"
DAILY_UPLOAD_COUNT=5

# --- GitHub Actions ---
# Repo → Settings → Secrets and variables → Actions → Repository secrets 에 동일 이름으로 등록
# 워크플로: .github/workflows/scheduled-pipeline.yml
# schedule cron 은 UTC (예: 한국 22:00 = 13:00 UTC)
