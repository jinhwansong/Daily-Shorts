# =============================================================================
# 복사: cp .env.example .env  (Windows: copy .env.example .env) 후 실제 값으로 교체
# dry-run 은 API 없이 FFmpeg 만 — npm run dry-run
# =============================================================================

# --- 필수 (실제 파이프라인) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PEXELS_API_KEY=

YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN_MYSTERY=
# 업로드 시 공개 범위 (미설정 시 private). 비공개로 올린 뒤 스튜디오 업로드 화면의 자동 안내(저작권·제한 등) 확인·설명란(스크립트) 번역 검수 후 직접 공개하면 됨.
# YOUTUBE_PRIVACY_STATUS=private
# YOUTUBE_PRIVACY_STATUS=unlisted
# YOUTUBE_PRIVACY_STATUS=public

# --- 선택: Claude 모델 (미설정 시 코드 기본과 동일) ---
CLAUDE_MODEL=claude-haiku-4-5-20251001

# --- 선택: Freesound BGM (https://freesound.org/apiv2/apply) ---
FREESOUND_API_KEY=
# 크레딧·CC BY 검색 여부·영상 EQ/CRF/BGM 볼륨 기본값은 src/utils/pipelineDefaults.js (여기서 env 로만 덮어쓸 때)
# FREESOUND_APPEND_CREDIT=0
# FREESOUND_ALLOW_ATTRIBUTION=1

# --- 선택: 훅 강도 — normal(기본) | strong
# strong = 주제·스크립트·제목/썸네일 문구에 더 세게 (실제 사건·사실 범위, 유튜브 안전 가이드 준수 전제)
CONTENT_HOOK_LEVEL=normal

# --- 선택: 하루 배치 기본 개수 (CLI --count 가 우선) ---
DAILY_UPLOAD_COUNT=5

# --- 선택: FFmpeg 영상 보정·압축 기본값은 pipelineDefaults.js (덮어쓸 때만)
# VIDEO_EQ_BRIGHTNESS=-0.06
# VIDEO_EQ_SATURATION=0.88
# VIDEO_CRF=21
# VIDEO_PRESET=medium
# VIDEO_SHARPEN=1

# --- 선택: 영상·오디오 자동 후처리 (기본 켬 / 0 으로 끔)
# 배경 2클립(반씩 이어 붙임): 기본 켬 — pipelineDefaults.js 의 VIDEO.DUAL_BACKGROUND. Pexels 호출·다운로드 2배. 단일 클립만 쓰려면:
# VIDEO_DUAL_BACKGROUND=0
# 정적 배경에 아주 약한 줌 (zoompan, FFmpeg 버전에 따라 실패 시 0)
VIDEO_KEN_BURNS=1
# zoompan 프레임당 증가·상한 (너무 크면 화면이 튐)
VIDEO_KEN_ZOOM_INC=0.00007
VIDEO_KEN_MAX_ZOOM=1.08
# 최종 믹스 라우드니즈 (YouTube 쪽 청감에 가깝게)
AUDIO_LOUDNORM=1
# AUDIO_LOUDNORM_I=-16
# AUDIO_LOUDNORM_TP=-1.5
# AUDIO_LOUDNORM_LRA=11

# --- 선택: 폰트 역할 분리 — 기본은 assets/fonts/fonts.json (썸네일≠자막)
# .env 에 아래를 쓰면 fonts.json 보다 우선합니다.
# THUMBNAIL_FONT_FILE=Anton-Regular.ttf
# THUMBNAIL_FONT_FAMILY=Anton
# 자막 ASS Fontname (미설정 시 fonts.json 의 subtitle.family, 예: Oswald)
SUBTITLE_FONT_NAME=
SUBTITLE_FONT_SIZE=78
# ARGB 16진 8자리 또는 RGB 6자리 (앞에 &H 생략 가능)
SUBTITLE_PRIMARY_ABGR=00F5F5F5
SUBTITLE_OUTLINE_ABGR=00000000
SUBTITLE_OUTLINE=5
SUBTITLE_SHADOW=3
# top = 상단 중앙(Shorts 모바일 하단 UI와 분리) | bottom = 하단 중앙
SUBTITLE_PLACEMENT=top
# 상단일 때는 화면 위에서 아래로 여백(px), 하단일 때는 아래에서 위로 여백
SUBTITLE_MARGIN_V=150
SUBTITLE_MARGIN_LR=48
SUBTITLE_SPACING=1
# 0 이면 볼드 해제
SUBTITLE_BOLD=1
# 다른 폴더에 폰트만 모아 둔 경우
# SUBTITLE_FONTS_DIR=E:/fonts/shorts

# --- 선택: TTS 대비 배경음 볼륨 (기본 pipelineDefaults.js) ---
# BGM_VOLUME=0.14

# --- 선택: YouTube 설명란 하단 고정 문구 (여러 줄은 \n 사용 가능) ---
YOUTUBE_ATTRIBUTION_FOOTER=Stock footage from Pexels. Voice and subtitles via AI.
