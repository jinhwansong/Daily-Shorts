# =============================================================================
# 비용 없이 로컬만 확인 (API 키 불필요)
# =============================================================================
# 1) FFmpeg 설치 → 터미널에서 ffmpeg -version 확인
# 2) npm install
# 3) npm run dry-run
#    → Claude/OpenAI/Pexels/YouTube 호출 없음. output/dry-run_*/final.mp4 로 합성만 검증
# =============================================================================
# 실제 업로드 테스트 (Claude·OpenAI 등 과금됨)
# =============================================================================
# 1) 이 파일을 복사해 ".env" 로 저장하고 아래 키 전부 채우기
# 2) npm run mystery  또는  node src/index.js --run-once --genre=mystery
# =============================================================================

# Anthropic (Claude)
ANTHROPIC_API_KEY=
# 기본: claude-haiku-4-5-20251001 (코드 기본값과 동일). 다른 모델 쓸 때만 설정
# CLAUDE_MODEL=claude-haiku-4-5-20251001

# OpenAI (TTS + Whisper)
OPENAI_API_KEY=

# Pexels
PEXELS_API_KEY=

# Freesound (선택) — https://freesound.org/apiv2/apply
# 있으면 매 영상마다 CC0(Creative Commons 0)만 검색해 프리뷰 MP3를 배경음으로 사용. 상업·유튜브에 제약 없음.
# 없으면 assets/bgm/<장르>.mp3 로컬 파일 폴백.
# FREESOUND_API_KEY=
# 설명란에 출처 한 줄 붙이지 않으려면: FREESOUND_APPEND_CREDIT=0 (CC BY 음원은 표기 의무로 무시됨)
# 검색에 CC BY(Attribution) 음원 포함: FREESOUND_ALLOW_ATTRIBUTION=1 — 자동으로 긴 출처 문구가 설명에 붙음

# Cursor MCP — GitHub API (Settings → MCP → mcp.json 의 github.env 에 붙이거나 OS 환경변수로 설정)
# GITHUB_PERSONAL_ACCESS_TOKEN=

# YouTube OAuth2
# Google Cloud Console에서 OAuth 클라이언트 1개 생성 (데스크톱 앱)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# --- 미스터리 채널 (Noctivault) — 지금 쓰는 채널 ---
# 발급: node scripts/getRefreshToken.js --channel=mystery
YOUTUBE_REFRESH_TOKEN_MYSTERY=

# --- 두 번째 채널(심리학) — 나중에 준비되면 입력. 비워두면 심리학 워크플로만 실패함 ---
# 발급: node scripts/getRefreshToken.js --channel=psychology
YOUTUBE_REFRESH_TOKEN_PSYCHOLOGY=

# 하루 배치 기본 개수 (--count 로 덮어씀)
DAILY_UPLOAD_COUNT=5

# 배경음 믹싱 볼륨 (0~1 권장, TTS 대비 BGM 크기). 로컬/Freesound BGM 있을 때 적용
# BGM_VOLUME=0.14
# 미스터리: assets/bgm/dark/*.mp3 | 심리학: assets/bgm/psychology/*.mp3 — Freesound 실패 시 무작위

# 설명란에 고정 저작권·출처 문구 추가 (선택) — Freesound 한 줄 다음에 붙음
# 여러 줄은 \n 로 구분하거나, assets/attribution_footer.txt 파일에 긴 문구 작성
# YOUTUBE_ATTRIBUTION_FOOTER=Music licensed under ...
