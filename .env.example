# =============================================================================
# 로컬에서 한 번 테스트 (GitHub Actions 돌리기 전에 권장)
# =============================================================================
# 1) 이 파일을 복사해 프로젝트 루트에 ".env" 로 저장하고 아래 키 전부 채우기
# 2) FFmpeg 설치 후 터미널에서 "ffmpeg -version" 이 되는지 확인
#    (Windows: https://ffmpeg.org 에서 받아 압축 해제 → bin 폴더를 시스템 PATH에 추가)
# 3) 프로젝트 루트에서:
#      npm install
#      npm run mystery
#    또는 미스터리 1편만:
#      node src/index.js --run-once --genre=mystery
# 4) 성공하면 output/ 폴더에 영상·로그 생성, YouTube Noctivault 채널에 실제 업로드됨(테스트 주의)
# =============================================================================

# Anthropic (Claude)
ANTHROPIC_API_KEY=
# 기본: claude-haiku-4-5-20251001 (코드 기본값과 동일). 다른 모델 쓸 때만 설정
# CLAUDE_MODEL=claude-haiku-4-5-20251001

# OpenAI (TTS + Whisper)
OPENAI_API_KEY=

# Pexels
PEXELS_API_KEY=

# YouTube OAuth2
# Google Cloud Console에서 OAuth 클라이언트 1개 생성 (데스크톱 앱)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# --- 미스터리 채널 (Noctivault) — 지금 쓰는 채널 ---
# 발급: node scripts/getRefreshToken.js --channel=mystery
YOUTUBE_REFRESH_TOKEN_MYSTERY=

# --- 두 번째 채널(심리학) — 나중에 준비되면 입력. 비워두면 심리학 워크플로만 실패함 ---
# 발급: node scripts/getRefreshToken.js --channel=psychology
YOUTUBE_REFRESH_TOKEN_PSYCHOLOGY=

DAILY_UPLOAD_COUNT=1
